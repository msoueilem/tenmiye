rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    function isActiveAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        exists(/databases/$(database)/documents/admins-simple/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/admins-simple/$(request.auth.token.email)).data.status == 'active';
    }

    match /users-simple/{uid} {
      allow read: if isSelf(uid) || isActiveAdmin();
      allow create, delete: if isActiveAdmin();
      allow update: if isActiveAdmin() || 
                    (isSelf(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'photoUrl']));
    }

    match /public-members/{uid} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /elections-simple/{electionId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /votes-simple/{voteId} {
      // Allow voters to check if they have voted, and admins to read all
      allow read: if isActiveAdmin() || (isSignedIn() && voteId.matches('^[^_]+_' + request.auth.uid + '$'));
      allow write: if false; 
    }

    match /nominations-simple/{nominationId} {
      allow read: if isActiveAdmin();
      allow write: if false;
    }

    match /nomination-counts/{countId} {
      allow read: if true;
      allow write: if false;
    }

    match /admins-simple/{email} {
      allow read: if isActiveAdmin() || (isSignedIn() && request.auth.token.email == email);
      allow write: if isActiveAdmin();
    }

    // Public create-only collections (Admins can read/manage)
    match /join-requests-simple/{document=**} {
      allow create: if true;
      allow read, update, delete: if isActiveAdmin();
    }

    match /messages-simple/{document=**} {
      allow create: if true;
      allow read, update, delete: if isActiveAdmin();
    }

    // Landing page settings doc(s)
    match /settings-simple/{document=**} {
      allow read: if true;
      allow write: if isActiveAdmin(); // allow dashboard saves for active admins
    }

    // Upload audit log
    match /uploads-simple/{docId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}