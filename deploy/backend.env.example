# Backend secrets for docker-compose. Copy to deploy/backend.env and fill in.
# (MONGODB_URI, PORT, UPLOADS_*, FRONTEND_URL are provided by docker-compose.yml.)
JWT_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_WEB_API_KEY=
FIREBASE_STORAGE_BUCKET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
# Email that receives full admin permissions from the seed script:
# SEED_ADMIN_EMAIL=owner@example.com
